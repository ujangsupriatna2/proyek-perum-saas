generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
//  MITRA (PARTNER)
// ═══════════════════════════════════════════════

model Mitra {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  subdomain   String   @unique
  logo        String   @default("")
  description String   @default("")
  address     String   @default("")
  phone       String   @default("")
  email       String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  admins       Admin[]
  properties   Property[]
  blogPosts    BlogPost[]
  testimonials Testimonial[]
  galleryItems GalleryItem[]
  banks        Bank[]
  settings     Setting[]
  services     Service[]
}

// ═══════════════════════════════════════════════
//  ADMIN
// ═══════════════════════════════════════════════

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  mitraId   String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])
}

// ═══════════════════════════════════════════════
//  PROPERTY
// ═══════════════════════════════════════════════

model Property {
  id               String   @id @default(cuid())
  mitraId          String?
  name             String
  slug             String
  type             String
  category         String   @default("inden")
  price            Float
  location         String   @default("Bandung Raya Residence")
  bedrooms         Int      @default(2)
  bathrooms        Int      @default(1)
  landArea         Float    @default(0)
  buildingArea     Float    @default(0)
  status           String   @default("available")
  description      String   @default("")
  features         String   @default("[]")
  images           String   @default("[]")
  tag              String   @default("")
  installment      String   @default("")
  financingTypes   String   @default("[\"syariah\",\"kpr\"]")
  dpOptions        String   @default("[30,35,40,45,50]")
  tenorOptions     String   @default("[1,2,3,4,5]")
  installments     String   @default("{}")
  syariahMargin    Float    @default(15)
  kprDpOptions     String   @default("[0,10,15,20,25,30]")
  kprTenorOptions  String   @default("[5,10,15,20,25]")
  kprInstallments  String   @default("{}")
  kprInterestRate  Float    @default(7.5)
  kprInterestType  String   @default("annuity")
  videoUrl         String   @default("")
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])

  @@unique([mitraId, slug])
}

// ═══════════════════════════════════════════════
//  BLOG POST
// ═══════════════════════════════════════════════

model BlogPost {
  id        String   @id @default(cuid())
  mitraId   String?
  title     String
  slug      String
  excerpt   String   @default("")
  content   String   @default("")
  category  String
  author    String   @default("Admin")
  image     String   @default("")
  published Boolean  @default(false)
  readTime  String   @default("5 menit")
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])

  @@unique([mitraId, slug])
}

// ═══════════════════════════════════════════════
//  TESTIMONIAL
// ═══════════════════════════════════════════════

model Testimonial {
  id        String   @id @default(cuid())
  mitraId   String?
  name      String
  role      String
  text      String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])
}

// ═══════════════════════════════════════════════
//  GALLERY ITEM
// ═══════════════════════════════════════════════

model GalleryItem {
  id          String   @id @default(cuid())
  mitraId     String?
  title       String
  category    String
  image       String
  description String   @default("")
  videoUrl    String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])
}

// ═══════════════════════════════════════════════
//  BANK
// ═══════════════════════════════════════════════

model Bank {
  id          String   @id @default(cuid())
  mitraId     String?
  name        String
  description String   @default("")
  image       String   @default("")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])
}

// ═══════════════════════════════════════════════
//  SETTING (per mitra)
// ═══════════════════════════════════════════════

model Setting {
  id        String   @id @default(cuid())
  mitraId   String?
  key       String
  value     String
  label     String   @default("")
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])

  @@unique([mitraId, key])
}

// ═══════════════════════════════════════════════
//  SERVICE (Jasa)
// ═══════════════════════════════════════════════

model Service {
  id          String   @id @default(cuid())
  mitraId     String?
  title       String
  slug        String
  description String   @default("")
  category    String
  price       Float
  priceUnit   String   @default("proyek")
  image       String   @default("")
  images      String   @default("[]")
  features    String   @default("[]")
  duration    String   @default("")
  videoUrl    String   @default("")
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  mitra Mitra? @relation(fields: [mitraId], references: [id])

  @@unique([mitraId, slug])
}

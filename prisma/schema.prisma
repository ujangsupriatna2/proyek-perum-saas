generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  type             String
  category         String   @default("inden")
  price            Float
  location         String   @default("Bandung Raya Residence")
  bedrooms         Int      @default(2)
  bathrooms        Int      @default(1)
  landArea         Float    @default(0)
  buildingArea     Float    @default(0)
  status           String   @default("available")
  description      String   @default("") @db.Text
  features         String   @default("[]")
  images           String   @default("[]")
  tag              String   @default("")
  installment      String   @default("")
  financingTypes   String   @default("[\"syariah\",\"kpr\"]")
  dpOptions        String   @default("[30,35,40,45,50]")
  tenorOptions     String   @default("[1,2,3,4,5]")
  installments     String   @default("{}")
  syariahMargin    Float    @default(15)
  kprDpOptions     String   @default("[0,10,15,20,25,30]")
  kprTenorOptions  String   @default("[5,10,15,20,25]")
  kprInstallments  String   @default("{}")
  kprInterestRate  Float    @default(7.5)
  kprInterestType  String   @default("annuity")
  videoUrl         String   @default("") @db.Text
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String   @default("") @db.Text
  content   String   @default("") @db.Text
  category  String
  author    String   @default("Admin BRR")
  image     String   @default("") @db.Text
  published Boolean  @default(false)
  readTime  String   @default("5 menit")
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  text      String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  image       String   @db.Text
  description String   @default("") @db.Text
  videoUrl    String   @default("") @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bank {
  id          String   @id @default(cuid())
  name        String
  description String   @default("") @db.Text
  image       String   @default("") @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String   @default("")
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
